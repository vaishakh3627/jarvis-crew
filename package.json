{
  "name": "jarvis-crew",
  "version": "0.1.4",
  "description": "A multi-agent coding CLI — talk to Atlas, who orchestrates a crew (Iris, Volt, Edith, Friday) that edits your code in parallel, right in your terminal. Runs on your Claude Code login.",
  "type": "module",
  "bin": {
    "jarvis": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "agents",
    "multi-agent",
    "coding",
    "claude",
    "claude-code",
    "ink",
    "tui",
    "terminal"
  ],
  "author": "Vaishakh K",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaishakh3627/jarvis-crew.git"
  },
  "homepage": "https://github.com/vaishakh3627/jarvis-crew#readme",
  "bugs": {
    "url": "https://github.com/vaishakh3627/jarvis-crew/issues"
  },
  "dependencies": {
    "ink": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
